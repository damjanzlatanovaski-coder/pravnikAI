# Google Gemini API Configuration
# Get your API key from: https://ai.google.dev/
# REQUIRED for AI features (search, translation, contract analysis)
GEMINI_API_KEY="your_gemini_api_key_here"

# Application URL
# Used for OAuth callbacks, self-referential links, and API endpoints
APP_URL="http://localhost:3000"

# Server Configuration
PORT=3000
NODE_ENV=development

# Database Configuration (for future use)
DATABASE_URL="postgresql://username:password@localhost:5432/pravnik_db"

# Optional: Production URL for CORS security
PROD_URL="https://pravnik.ai"

# Optional: Disable HMR for AI Studio environments
DISABLE_HMR=false

# Optional: Session secret for encryption
SESSION_SECRET="your_secret_key_here"
